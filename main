<script>
document.addEventListener('DOMContentLoaded', function() {

  // ─── CALCULATOR ───
  (function() {
    var budgetEl = document.getElementById('calc-budget');
    var cplEl    = document.getElementById('calc-cpl');
    var valueEl  = document.getElementById('calc-value');
    if (!budgetEl) return;
    function fmt(n, decimals) { return n.toFixed(decimals || 0).replace(/\B(?=(\d{3})+(?!\d))/g, ','); }
    function update() {
      var budget = parseFloat(budgetEl.value);
      var cpl    = parseFloat(cplEl.value);
      var val    = parseFloat(valueEl.value);
      var monthlySpend = budget * 30;
      var subs = Math.round(monthlySpend / cpl);
      var revenue = subs * 0.01 * val;
      var roi  = revenue / monthlySpend;
      document.getElementById('calc-budget-val').textContent = '$' + fmt(budget) + '/day';
      document.getElementById('calc-cpl-val').textContent    = '$' + fmt(cpl, 2);
      document.getElementById('calc-value-val').textContent  = '$' + fmt(val);
      document.getElementById('res-subs').textContent        = fmt(subs);
      document.getElementById('res-spend').textContent       = '$' + fmt(monthlySpend);
      document.getElementById('res-revenue').textContent     = '$' + fmt(revenue);
      document.getElementById('res-roi').textContent         = fmt(roi, 1) + '\u00D7';
    }
    budgetEl.addEventListener('input', update);
    cplEl.addEventListener('input', update);
    valueEl.addEventListener('input', update);
    update();
  })();

  // ─── MODULE STACKING CARDS ───
  (function() {
    var modules = [
      { num: '01', label: 'Lay the Foundation', title: 'Ads Strategy', desc: 'Two ways to capture leads (native forms vs. landing pages), which we recommend and why, whether Zapier is worth the cost, and how $5/day compounds into real growth.' },
      { num: '02', label: 'Make Them Stop Scrolling', title: 'Creative & Copy', desc: 'Ad creative best practices, safe zones for text placement, and writing copy with a simple problem \u2192 solution \u2192 benefit framework. Plus templates so you never start from a blank page.' },
      { num: '03', label: 'Get Everything Connected', title: 'Facebook: Setting Up', desc: 'Creating your business page, Meta Business Suite, connecting Instagram, ad account setup, payment, 2FA, and the Meta Pixel. Screenshots for every single step.' },
      { num: '04', label: 'Build Your First Campaign', title: 'Setting Up Your 1st Campaign', desc: 'We build it together. Choosing your objective, audience, budget, placements, and ad variations. Your first campaign doesn\u2019t need to be perfect. You got this!' },
      { num: '05', label: 'Turn Leads Into Clients', title: 'Nurture Your Opt-Ins', desc: 'Your ad gets them to raise their hand. This module is what happens next, and where the real relationship starts. Set this up before you launch.' },
      { num: '06', label: 'Know Your Numbers', title: 'Reading Your Results', desc: 'Which numbers actually matter, what \u2018good\u2019 looks like for your niche, and how to tell if your campaign is working. Just the stuff you need to make smart decisions.' },
      { num: '07', label: 'Fix It Fast', title: 'Troubleshooting & FAQ', desc: 'Ad rejected? Results look off? Account flagged? We cover the most common hiccups so you can fix them fast and keep moving.' }
    ];

    var container = document.getElementById('stack-container');
    if (!container) return;

    modules.forEach(function(m) {
      var card = document.createElement('div');
      card.className = 'stack-card';
      card.innerHTML =
        '<div class="stack-card-header">' +
          '<span class="card-num">' + m.num + '</span>' +
          '<span>' + m.label + '</span>' +
        '</div>' +
        '<div class="stack-card-body">' +
          '<h3>' + m.title + '</h3>' +
          '<p>' + m.desc + '</p>' +
          '<div class="stack-card-placeholder">' +
            '<div class="stack-card-placeholder-icon">\uD83D\uDDBC</div>' +
            '<div class="stack-card-placeholder-text">Mockup coming soon</div>' +
            '<div class="stack-card-placeholder-sub">Recommended: 900 \u00D7 500px</div>' +
          '</div>' +
        '</div>';
      container.appendChild(card);
    });
  })();

  // ─── FAQ ACCORDION ───
  document.querySelectorAll('.faq-q').forEach(function(q) {
    q.addEventListener('click', function() {
      var a = q.nextElementSibling;
      var isOpen = a.classList.contains('open');
      document.querySelectorAll('.faq-a.open').forEach(function(el) { el.classList.remove('open'); el.previousElementSibling.classList.remove('open'); });
      if (!isOpen) { a.classList.add('open'); q.classList.add('open'); }
    });
  });

  // ─── OBJECTIONS ACCORDION ───
  document.querySelectorAll('.obj-q').forEach(function(q) {
    q.addEventListener('click', function() {
      var a = q.nextElementSibling;
      var isOpen = a.classList.contains('open');
      document.querySelectorAll('.obj-a.open').forEach(function(el) { el.classList.remove('open'); el.previousElementSibling.classList.remove('open'); });
      if (!isOpen) { a.classList.add('open'); q.classList.add('open'); }
    });
  });

  // ─── ENGINE SWIPE HINT ───
  (function() {
    var steps = document.querySelector('.engine-steps');
    var hint  = document.getElementById('engine-hint');
    if (!steps || !hint) return;
    steps.addEventListener('scroll', function() {
      hint.style.transition = 'opacity 0.4s';
      hint.style.opacity = '0';
    }, { once: true });
  })();

  // ─── STAT COUNTUP ───
  (function() {
    var stats = [
      { id: 'stat-0', target: 1.27, decimals: 2, prefix: '$', suffix: '' },
      { id: 'stat-1', target: 171,  decimals: 0, prefix: '',  suffix: '' },
      { id: 'stat-2', target: 3,   decimals: 0, prefix: '',  suffix: '\u00D7' }
    ];
    var fired = false;
    function runCountup() {
      if (fired) return;
      fired = true;
      stats.forEach(function(s, i) {
        var el = document.getElementById(s.id);
        if (!el) return;
        var duration = 1400;
        var start = null;
        setTimeout(function() {
          function step(ts) {
            if (!start) start = ts;
            var prog = Math.min((ts - start) / duration, 1);
            var ease = 1 - Math.pow(1 - prog, 3);
            el.textContent = s.prefix + (s.target * ease).toFixed(s.decimals) + s.suffix;
            if (prog < 1) { requestAnimationFrame(step); }
            else { el.textContent = s.prefix + s.target.toFixed(s.decimals) + s.suffix; }
          }
          requestAnimationFrame(step);
        }, i * 180);
      });
    }
    var grid = document.getElementById('stats-grid');
    if (grid && 'IntersectionObserver' in window) {
      var obs = new IntersectionObserver(function(entries) {
        if (entries[0].isIntersecting) { runCountup(); obs.disconnect(); }
      }, { threshold: 0.3 });
      obs.observe(grid);
    } else {
      setTimeout(runCountup, 800);
    }
  })();

  // ─── CHECKLIST ANIMATION ───
  var checklistItems = document.querySelectorAll('#checklist li');
  if (checklistItems.length > 0) {
    var checklistObserver = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (e.isIntersecting) {
          checklistItems.forEach(function(li, i) {
            setTimeout(function() { li.classList.add('visible'); }, i * 200);
          });
          checklistObserver.unobserve(e.target);
        }
      });
    }, { threshold: 0.3 });
    checklistObserver.observe(checklistItems[0]);
  }

});
</script>

</body>
</html>
